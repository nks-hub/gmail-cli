{
  "name": "gmail-cli",
  "version": "0.1.0",
  "description": "A fast, scriptable Gmail command-line client with first-class JSON output.",
  "license": "MIT",
  "type": "module",
  "module": "src/index.ts",
  "bin": {
    "gmail": "./src/index.ts"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "bun build src/index.ts --compile --outfile dist/gmail"
  },
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "typescript": "^5.7.0"
  }
}
